{
  "network": "base",
  "currency": "USDC",
  "services": {
    "deep-analysis": {
      "price": "0.35",
      "description": "Deep Project Due Diligence Analysis - Risk assessment, tokenomics, team review and recommendation for any Base token or project",
      "schema": {
        "input": {
          "type": "object",
          "properties": {
            "contractAddress": {
              "type": "string",
              "description": "Contract address on Base (optional)"
            },
            "projectName": {
              "type": "string",
              "description": "Project name to analyze (optional)"
            },
            "ticker": {
              "type": "string",
              "description": "Token ticker symbol (optional)"
            }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "projectName": { "type": "string", "description": "Project name" },
            "ticker": { "type": "string", "description": "Token ticker" },
            "overallScore": { "type": "number", "description": "Overall score 0-100" },
            "riskScore": { "type": "number", "description": "Risk score 0-100 (higher = riskier)" },
            "rugProbability": { "type": "number", "description": "Rug pull probability 0-100" },
            "recommendation": { "type": "string", "description": "Strong Buy | Buy | Caution | Avoid | High Risk" },
            "summary": { "type": "string", "description": "Professional analysis summary" }
          }
        }
      }
    }
  }
}
